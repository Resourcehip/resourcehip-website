# Build output — Cloudflare Pages rebuilds from source on every deploy
dist/

# Brand assets and editorial content — managed outside version control
brand/
editorial/

# Python virtual environment and bytecode
.venv/
__pycache__/
*.pyc

# Hermes agent logs and session dumps (prevent accidental commits)
20260*/
*_[a-f0-9]{8}
*.session.log
*.session*.json
*.session*.jsonl

# Environment and secrets
.env
.env.local
*.key
*.pem
*.pkcs12

# Build caches
.hero-cache.json

# Temporary files
*.tmp
*.bak
*~

# OS files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
/logs/
/tmp/
