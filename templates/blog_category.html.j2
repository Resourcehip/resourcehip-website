{% extends "base.html.j2" %}

{% block extra_styles %}
.cat-header { margin-bottom: 2rem; }
.breadcrumb { font-size: 0.8rem; color: #888; margin-bottom: 0.5rem; }
.breadcrumb a { color: var(--forest-green); text-decoration: none; }
.breadcrumb a:hover { text-decoration: underline; }
.cat-header h1 { font-size: 1.75rem; margin-bottom: 0.75rem; }

/* rating_link() output in this template */
.rating-link {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  background: #eef4e8;
  border: 1px solid #c0d8a8;
  color: var(--forest-green);
  font-weight: 600;
  font-size: 0.88rem;
  padding: 0.4rem 1rem;
  border-radius: 6px;
  text-decoration: none;
}
.rating-link:hover { background: #deefd0; }

.post-list { list-style: none; padding: 0; margin: 2rem 0 0; }
.post-list li {
  border-bottom: 1px solid var(--border);
  padding: 1.25rem 0;
}
.post-list li:last-child { border-bottom: none; }
.post-list .post-date { font-size: 0.75rem; color: #888; margin-bottom: 0.3rem; }
.post-list h2 { font-size: 1.05rem; font-weight: 700; margin: 0 0 0.35rem; border: none; }
.post-list h2 a { color: var(--impact-grey); text-decoration: none; }
.post-list h2 a:hover { color: var(--forest-green); }
.post-list .post-desc { font-size: 0.85rem; color: #666; line-height: 1.6; margin: 0; }

.back-link { display: inline-block; margin-top: 2rem; font-size: 0.85rem; color: var(--forest-green); }
{% endblock %}

{% block content %}
<div class="cat-header">
  <p class="breadcrumb"><a href="/blog/">Blog</a> / {{ category_slug | replace("-", " ") | title }}</p>
  <h1>{{ category_slug | replace("-", " ") | title }}</h1>
  {{ rating_link(category_slug) }}
</div>

{% if posts %}
<ul class="post-list" role="list">
  {% for post in posts %}
  <li role="listitem">
    <div class="post-date">{{ post.last_updated }}</div>
    <h2><a href="/blog/{{ post.slug }}/">{{ post.title }}</a></h2>
    {% if post.description %}
    <p class="post-desc">{{ post.description }}</p>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% else %}
<p style="color:#888;margin-top:2rem;">No posts in this category yet.</p>
{% endif %}

<a class="back-link" href="/blog/">← All posts</a>
{% endblock %}
