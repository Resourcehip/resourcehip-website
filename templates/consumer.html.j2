{% extends "base.html.j2" %}

{% block main_class %}landing{% endblock %}

{% block extra_styles %}
    .site-main.landing { max-width: none; padding: 0; }

    /* ── §2a Hero ── */
    .consumer-hero {
      position: relative;
      min-height: 480px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      background: var(--hip-blue);
    }

    .consumer-hero-bg {
      position: absolute;
      inset: 0;
      background: url('/assets/marketing/anchor/identity-v1.png') center center / cover no-repeat;
      z-index: 0;
    }

    .consumer-hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(10, 36, 64, 0.35) 0%,
        rgba(10, 36, 64, 0.55) 100%
      );
      z-index: 1;
    }

    .consumer-hero-mark {
      position: absolute;
      bottom: 1.5rem;
      left: 1.5rem;
      width: 96px;
      height: auto;
      z-index: 3;
      filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3));
    }

    .consumer-hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 680px;
      padding: 4rem 2rem;
    }

    .consumer-hero h1 {
      font-size: clamp(1.75rem, 4vw, 2.8rem);
      font-weight: 700;
      color: #fff;
      margin-bottom: 1rem;
      line-height: 1.2;
    }

    .consumer-hero-lede {
      font-size: clamp(0.9rem, 1.8vw, 1.1rem);
      color: rgba(255,255,255,0.9);
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    .consumer-hero-ctas {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }

    .cta-primary,
    .cta-secondary {
      display: inline-block;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-decoration: none;
      padding: 0.8rem 1.8rem;
      border-radius: 8px;
      transition: opacity 0.2s, transform 0.15s;
    }

    .cta-primary {
      background: #fff;
      color: var(--hip-blue);
    }

    .cta-secondary {
      background: transparent;
      color: #fff;
      border: 2px solid rgba(255,255,255,0.6);
    }

    .cta-primary:hover,
    .cta-secondary:hover {
      opacity: 0.9;
      transform: translateY(-1px);
    }

    /* ── §2b Mark tier strip ── */
    .mark-strip {
      background: var(--page-bg);
      padding: 4rem 2rem;
    }

    .mark-strip-inner {
      max-width: 1000px;
      margin: 0 auto;
    }

    .mark-cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .mark-card {
      background: var(--card-bg);
      border: 1px solid var(--rule);
      border-radius: 14px;
      padding: 2rem 1.5rem;
      text-align: center;
      text-decoration: none;
      color: var(--ink);
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .mark-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 28px rgba(14,76,143,0.1);
      border-color: var(--hip-blue);
      color: var(--ink);
    }

    .mark-card-badge {
      width: 80px;
      height: auto;
      margin-bottom: 0.5rem;
    }

    .mark-card-tier {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--mark-black);
    }

    .mark-card-body {
      font-size: 0.88rem;
      line-height: 1.6;
      color: var(--muted);
    }

    @media (max-width: 768px) {
      .mark-cards { grid-template-columns: 1fr; max-width: 400px; margin: 0 auto; }
    }

    /* ── §2c How a rating works ── */
    .how-strip {
      background: var(--surface);
      padding: 4rem 2rem;
    }

    .how-strip-inner {
      max-width: 900px;
      margin: 0 auto;
    }

    .how-strip-image {
      width: 100%;
      max-width: 1200px;
      height: auto;
      border-radius: 12px;
      margin-bottom: 2rem;
    }

    .how-strip h2 {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--ink);
      margin: 0 0 1.5rem;
    }

    .how-strip p {
      font-size: 0.95rem;
      line-height: 1.75;
      color: var(--ink);
    }

    .how-strip-link {
      display: inline-block;
      margin-top: 1rem;
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--hip-blue);
      text-decoration: none;
    }

    .how-strip-link:hover { text-decoration: underline; }

    /* ── §2d Category teaser grid ── */
    .category-strip {
      background: var(--page-bg);
      padding: 4rem 2rem;
    }

    .category-strip-inner {
      max-width: 1100px;
      margin: 0 auto;
    }

    .category-strip h2 {
      font-size: 1.35rem;
      font-weight: 700;
      color: var(--ink);
      text-align: center;
      margin: 0 0 2rem;
    }

    .category-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.25rem;
    }

    .category-card {
      background: var(--card-bg);
      border: 1px solid var(--rule);
      border-radius: 12px;
      padding: 1.5rem;
      text-decoration: none;
      color: var(--ink);
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .category-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(14,76,143,0.1);
      border-color: var(--hip-blue);
      color: var(--ink);
    }

    .category-card-title {
      font-size: 1rem;
      font-weight: 700;
      color: var(--mark-black);
    }

    .category-card-score {
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--muted);
    }

    .category-card-badge {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--muted);
      margin-top: auto;
      padding-top: 0.5rem;
    }

    .category-card-badge.has-mark { color: var(--tier-emerald-text); }

    @media (max-width: 640px) {
      .consumer-hero-content { padding: 3rem 1.5rem; }
      .mark-strip,
      .how-strip,
      .category-strip { padding: 2.5rem 1.5rem; }
    }
{% endblock %}

{% block content %}

  {# ── §2a Hero ── #}
  <section class="consumer-hero" aria-label="Consumer hero">
    <div class="consumer-hero-bg" aria-hidden="true"></div>
    <div class="consumer-hero-overlay" aria-hidden="true"></div>
    <img
      class="consumer-hero-mark"
      src="/assets/marks/hip-mark-shield-standard.svg"
      alt="HIP Mark — Standard"
      width="96" height="96"
    />
    <div class="consumer-hero-content">
      <h1>Check before you buy.</h1>
      <p class="consumer-hero-lede">
        We rate everyday products on how well they last,
        what they're made of, and what's left at the end.
        Free. Independent. Built in Scotland.
      </p>
      <div class="consumer-hero-ctas">
        <a class="cta-primary" href="/ratings/">See your category</a>
        <a class="cta-secondary" href="/consumer/mark/">What does the mark mean?</a>
      </div>
    </div>
  </section>

  {# ── §2b Mark tier strip ── #}
  <section class="mark-strip" aria-label="HIP Mark tiers">
    <div class="mark-strip-inner">
      <div class="mark-cards">

        <a class="mark-card" href="/consumer/mark/#standard">
          <img class="mark-card-badge" src="/assets/marks/hip-mark-shield-standard.svg" alt="HIP Mark Standard" width="80" />
          <span class="mark-card-tier">A solid baseline.</span>
          <span class="mark-card-body">Built to last and avoids the worst materials.</span>
        </a>

        <a class="mark-card" href="/consumer/mark/#silver">
          <img class="mark-card-badge" src="/assets/marks/hip-mark-shield-silver.svg" alt="HIP Mark Silver" width="80" />
          <span class="mark-card-tier">A real step up.</span>
          <span class="mark-card-body">Better materials, easier to repair, more recyclable.</span>
        </a>

        <a class="mark-card" href="/consumer/mark/#gold">
          <img class="mark-card-badge" src="/assets/marks/hip-mark-shield-gold.svg" alt="HIP Mark Gold" width="80" />
          <span class="mark-card-tier">Best in its category.</span>
          <span class="mark-card-body">Top scores across all seven dimensions we check. Verified by us.</span>
        </a>

      </div>
    </div>
  </section>

  {# ── §2c How a rating works ── #}
  <section class="how-strip" aria-label="How a rating works">
    <div class="how-strip-inner">
      <img
        class="how-strip-image"
        src="/assets/marketing/about/hip-mark-explainer-v1.png"
        alt="HIP Mark tiers explained — Standard, Silver, and Gold"
        loading="lazy"
      />
      <h2>How a rating works</h2>
      <p>
        We score products from 0 to 10. The score covers seven things, from how rare
        the materials are, to how easy the product is to repair, to what happens
        when you've finished with it.
      </p>
      <p>
        A product earns a mark when its score is high enough. Standard at 6.0,
        Silver at 7.5, Gold at 9.0. Below 6.0, no mark — but you still see the score.
      </p>
      <p>
        We start cautious. Most everyday products score low because we assume the
        worst when the maker hasn't shared data. Real data nearly always lifts the
        score. That's the point.
      </p>
      <a class="how-strip-link" href="/methodology">See the full method &rarr;</a>
    </div>
  </section>

  {# ── §2d Category teaser grid ── #}
  <section class="category-strip" aria-label="Category ratings">
    <div class="category-strip-inner">
      <h2>Explore category ratings</h2>
      <div class="category-grid">
        {% for r in ratings[:8] %}
        <a class="category-card" href="/ratings/{{ r.slug }}">
          <span class="category-card-title">{{ r.title }}</span>
          <span class="category-card-score">{{ '%.1f' | format(r.hip_score) }} / 10</span>
          {% if r.hip_score >= 9.0 %}
            <span class="category-card-badge has-mark">Gold</span>
          {% elif r.hip_score >= 7.5 %}
            <span class="category-card-badge has-mark">Silver</span>
          {% elif r.hip_score >= 6.0 %}
            <span class="category-card-badge has-mark">Standard</span>
          {% else %}
            <span class="category-card-badge">No mark yet &mdash; typical for the category</span>
          {% endif %}
        </a>
        {% endfor %}
      </div>
    </div>
  </section>

{% endblock %}
