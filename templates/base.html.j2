<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }} — Resourcehip</title>
  <meta name="description" content="{{ page_description | default('Resourcehip — Human Impact Profiles for everyday products.') }}" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- Self-hosted Montserrat — no Google Fonts CDN (GDPR: no IP sent to Google) -->
  <!-- Run fonts/download_fonts.py once to fetch the .woff2 files -->
  <link rel="stylesheet" href="/fonts/montserrat.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Brand ── */
      --hip-blue:        #0E4C8F;
      --hip-blue-deep:   #0A3A6E;
      --hip-blue-tint:   #E6EEF7;
      /* ── Neutrals (warm) ── */
      --mark-black:      #1A1A1A;
      --ink:             #2E3742;
      --muted:           #5C6773;
      --rule:            #DDD9CD;
      --surface:         #F6F4EE;
      --page-bg:         #FBFAF6;
      --card-bg:         #FFFFFF;
      /* ── Footer / inverse ── */
      --footer-bg:       #0A2440;
      --footer-fg:       #F6F4EE;
      --footer-link:     #A8C4E6;
      /* ── HIP Mark tier colours (brand-locked — do not adjust) ── */
      --tier-emerald:    #3a9e62;
      --tier-slate:      #7a9ab8;
      --tier-amber:      #c8920a;
      /* ── Tier text-safe variants (WCAG AA body text on --page-bg — §3.4 colour spec v1.1) ── */
      --tier-emerald-text: #2a6e44;
      --tier-slate-text:   #4a6a88;
      --tier-amber-text:   #8a5a00;
      /* ── Regenerative Index ramp (methodology data viz — §3.5 colour spec) ── */
      --ri-depleting:    #c04040;
      --ri-extractive:   #c8920a;
      --ri-renewable:    #4FA9A5;
      --ri-restorative:  #7ab85a;
      --ri-regenerative: #3a9e62;
      /* ── Functional ── */
      --positive:        #3a9e62;
      --negative:        #B5482E;
      --warning-bg:      #FFF8E6;
      --warning-fg:      #6B5400;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--page-bg);
      color: var(--ink);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ─────────────────────────────────────────────────────────── */
    .site-header {
      background: #fff;
      border-bottom: 1px solid var(--rule);
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 1px 8px rgba(0,0,0,0.06);
    }

    .site-header .logo-link img {
      height: 48px;
      width: auto;
      display: block;
    }

    .site-nav {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .site-nav a {
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      transition: color 0.2s;
    }

    .site-nav a:hover,
    .site-nav a.active { color: var(--hip-blue); }

    .site-nav a.nav-cta {
      background: linear-gradient(135deg, var(--hip-blue), var(--hip-blue-deep));
      color: #fff;
      padding: 0.45rem 1.1rem;
      border-radius: 6px;
      letter-spacing: 0.06em;
    }

    .site-nav a.nav-cta:hover { opacity: 0.9; color: #fff; }

    /* ── Main content area ──────────────────────────────────────────────── */
    .site-main {
      flex: 1;
      width: 100%;
      max-width: 900px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
    }

    .site-main.wide {
      max-width: 1100px;
    }

    /* ── Shared card ────────────────────────────────────────────────────── */
    .card {
      background: var(--card-bg);
      border: 1px solid var(--rule);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }

    /* ── Shared typography ──────────────────────────────────────────────── */
    h1 { font-size: 1.75rem; font-weight: 700; color: var(--mark-black); margin-bottom: 0.5rem; }
    h2 { font-size: 1.2rem; font-weight: 700; color: var(--ink); margin: 2rem 0 0.75rem; }
    h3 { font-size: 1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
    p  { line-height: 1.75; margin-bottom: 1rem; }
    a  { color: var(--hip-blue); }
    ul, ol { padding-left: 1.4rem; line-height: 1.8; }

    hr { border: none; border-top: 1px solid var(--rule); margin: 2rem 0; }

    /* ── Pill / badge ────────────────────────────────────────────────────── */
    .pill {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 20px;
      background: var(--surface);
      color: var(--ink);
    }

    /* ── Skip link (WCAG 2.4.1 Bypass Blocks) ─────────────────────────── */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 0;
      background: var(--hip-blue);
      color: #fff;
      padding: 0.6rem 1.2rem;
      z-index: 9999;
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      border-radius: 0 0 6px 0;
      transition: top 0.15s;
    }
    .skip-link:focus { top: 0; }

    /* ── Focus styles (WCAG 2.4.7 Focus Visible) ────────────────────── */
    *:focus-visible {
      outline: 3px solid var(--hip-blue);
      outline-offset: 3px;
      border-radius: 3px;
    }

    /* ── Footer ─────────────────────────────────────────────────────────── */
    .site-footer {
      background: var(--footer-bg);
      color: var(--footer-fg);
      text-align: center;
      padding: 1.5rem 2rem;
      font-size: 0.72rem;
      letter-spacing: 0.05em;
    }

    .site-footer a { color: var(--footer-link); text-decoration: none; }

    /* ── Search widget ──────────────────────────────────────────────────── */
    .search-wrapper { position: relative; margin-left: auto; }
    .search-wrapper input[type="search"] {
      font-family: 'Montserrat', sans-serif;
      font-size: 0.78rem;
      padding: 0.4rem 0.8rem;
      border: 1px solid var(--rule);
      border-radius: 6px;
      width: 170px;
      background: var(--page-bg);
      color: var(--ink);
      transition: width 0.2s, border-color 0.2s;
    }
    .search-wrapper input[type="search"]:focus {
      width: 240px;
      border-color: var(--hip-blue);
      outline: none;
    }
    .search-results {
      display: none;
      position: absolute;
      top: 100%;
      right: 0;
      width: 360px;
      max-height: 420px;
      overflow-y: auto;
      background: var(--card-bg);
      border: 1px solid var(--rule);
      border-radius: 8px;
      box-shadow: 0 8px 30px rgba(0,0,0,0.12);
      z-index: 200;
      margin-top: 0.5rem;
    }
    .search-result {
      display: block;
      padding: 0.75rem 1rem;
      text-decoration: none;
      color: inherit;
      border-bottom: 1px solid var(--rule);
      transition: background 0.15s;
    }
    .search-result:last-child { border-bottom: none; }
    .search-result:hover, .search-result.search-active { background: var(--surface); }
    .search-result-name {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .search-result-meta {
      font-size: 0.72rem;
      color: #888;
      margin-top: 0.15rem;
    }
    .search-badge {
      font-size: 0.58rem; font-weight: 700;
      padding: 0.1rem 0.4rem; border-radius: 8px;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .search-badge-verified { background: var(--hip-blue-tint); color: var(--hip-blue); }
    .search-badge-ceiling { background: var(--surface); color: #888; }
    .search-no-results {
      padding: 1rem; color: #aaa; font-size: 0.82rem; text-align: center;
    }

    /* ── Responsive ─────────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header { padding: 0.75rem 1rem; }
      .site-nav { gap: 1rem; }
      .site-nav a.nav-cta { display: none; }
      .site-main { padding: 1.5rem 1rem 3rem; }
      .search-wrapper input[type="search"] { width: 120px; font-size: 0.72rem; }
      .search-wrapper input[type="search"]:focus { width: 160px; }
      .search-results { width: 280px; }
    }

    {% block extra_styles %}{% endblock %}
  </style>
  {% block head_meta %}{% endblock %}
</head>
<body>

  <!-- Skip to main content (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="site-header">
    <a class="logo-link" href="/">
      <img src="/assets/hip-lockup.png" alt="Resourcehip — HIP Certified" />
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href="/" {% if active_page == 'home' %}class="active" aria-current="page"{% endif %}>Home</a>
      <a href="/ratings/" {% if active_page == 'ratings' %}class="active" aria-current="page"{% endif %}>Ratings</a>
      <a href="/blog/" {% if active_page == 'blog' %}class="active" aria-current="page"{% endif %}>Blog</a>
      <a href="/methodology" {% if active_page == 'methodology' %}class="active" aria-current="page"{% endif %}>Methodology</a>
      <a href="/about" {% if active_page == 'about' %}class="active" aria-current="page"{% endif %}>About</a>
      <a href="/contact" {% if active_page == 'contact' %}class="active" aria-current="page"{% endif %}>Contact</a>
      <a href="/faq" {% if active_page == 'faq' %}class="active" aria-current="page"{% endif %}>FAQ</a>
      <a href="/verified-ratings" {% if active_page == 'verified-ratings' %}class="active" aria-current="page"{% endif %}>Verified Ratings</a>
      <a href="/pricing" {% if active_page == 'pricing' %}class="active" aria-current="page"{% endif %}>Pricing</a>
      <div class="search-wrapper">
        <input type="search" id="rh-search-input" placeholder="Search products..." autocomplete="off" aria-label="Search products">
        <div id="rh-search-results" class="search-results" role="listbox" aria-label="Search results"></div>
      </div>
      <a href="/submit" class="nav-cta">Submit a Product</a>
    </nav>
  </header>

  <main id="main-content" class="site-main {% block main_class %}{% endblock %}">
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer">
    <div>&copy; 2026 Resourcehip Ltd &nbsp;&middot;&nbsp; Reg. SC873386 &nbsp;&middot;&nbsp; Office 90, Alloa Business Centre, Whins Road, Alloa, Clackmannanshire, FK10&nbsp;3SA, Scotland</div>
    <!-- TODO: add VAT no. once registered (only required if VAT-registered) -->
    <div style="margin-top:0.4rem;">
      <span id="rh-email"></span> &nbsp;|&nbsp;
      <a href="/contact">Contact</a> &nbsp;|&nbsp;
      <a href="/methodology">Methodology v{{ methodology_version | default('1.3') }}</a> &nbsp;|&nbsp;
      <a href="/privacy">Privacy</a> &nbsp;|&nbsp;
      <a href="/terms">Terms</a> &nbsp;|&nbsp;
      <a href="/cookies">Cookies &amp; AI</a>
    </div>
  </footer>
  <script>
    /* Email obfuscation — assembled at runtime to deter address harvesting bots */
    (function() {
      var u = 'hello', d = ['resourcehip', 'com'].join('.');
      var addr = u + '\u0040' + d;
      var el = document.getElementById('rh-email');
      if (el) el.innerHTML = '<a href="mailto:' + addr + '">' + addr + '</a>';
    })();
  </script>
  <script>
    (function() {
      var index = null, active = -1;
      var input = document.getElementById('rh-search-input');
      var box = document.getElementById('rh-search-results');
      if (!input || !box) return;

      var TYPE_RANK = { manufacturer: 0, generic: 1, ceiling: 2 };

      function load() {
        if (index) return Promise.resolve(index);
        return fetch('/search-index.json')
          .then(function(r) { return r.json(); })
          .then(function(d) { index = d; return d; })
          .catch(function() { index = []; return []; });
      }

      function esc(s) {
        var d = document.createElement('div');
        d.textContent = s || '';
        return d.innerHTML;
      }

      function render(items) {
        active = -1;
        if (!items.length) {
          box.innerHTML = '<div class="search-no-results">No results found</div>';
          box.style.display = 'block';
          return;
        }
        box.innerHTML = items.map(function(it, i) {
          var badge = it.type === 'manufacturer'
            ? ' <span class="search-badge search-badge-verified">Verified</span>'
            : it.type === 'ceiling'
            ? ' <span class="search-badge search-badge-ceiling">Ceiling</span>'
            : '';
          var ri = (it.riScore > 0 ? '+' : '') + it.riScore.toFixed(1);
          return '<a class="search-result" href="' + esc(it.url) + '" role="option" data-idx="' + i + '">'
            + '<div class="search-result-name">' + esc(it.name) + badge + '</div>'
            + '<div class="search-result-meta">' + esc(it.category) + ' &middot; HIP ' + it.hipScore.toFixed(1) + ' &middot; RI ' + ri + '</div>'
            + '</a>';
        }).join('');
        box.style.display = 'block';
      }

      function search(q) {
        if (!index || !q) { box.innerHTML = ''; box.style.display = 'none'; return; }
        var lq = q.toLowerCase();
        var hits = [];
        for (var i = 0; i < index.length; i++) {
          var it = index[i];
          var nameMatch = (it.name || '').toLowerCase().indexOf(lq) !== -1;
          var catMatch = (it.category || '').toLowerCase().indexOf(lq) !== -1;
          var brandMatch = it.brand && it.brand.toLowerCase().indexOf(lq) !== -1;
          if (nameMatch || catMatch || brandMatch) hits.push(it);
        }
        hits.sort(function(a, b) {
          var ta = TYPE_RANK[a.type] !== undefined ? TYPE_RANK[a.type] : 1;
          var tb = TYPE_RANK[b.type] !== undefined ? TYPE_RANK[b.type] : 1;
          if (ta !== tb) return ta - tb;
          var aStart = (a.name || '').toLowerCase().indexOf(lq) === 0 ? 0 : 1;
          var bStart = (b.name || '').toLowerCase().indexOf(lq) === 0 ? 0 : 1;
          if (aStart !== bStart) return aStart - bStart;
          return (b.hipScore || 0) - (a.hipScore || 0);
        });
        render(hits.slice(0, 12));
      }

      function setActive(idx) {
        var items = box.querySelectorAll('.search-result');
        if (active >= 0 && active < items.length) items[active].classList.remove('search-active');
        active = idx;
        if (active >= 0 && active < items.length) {
          items[active].classList.add('search-active');
          items[active].scrollIntoView({ block: 'nearest' });
        }
      }

      input.addEventListener('focus', function() { load(); });
      input.addEventListener('input', function() {
        load().then(function() { search(input.value.trim()); });
      });
      input.addEventListener('keydown', function(e) {
        var items = box.querySelectorAll('.search-result');
        if (!items.length) return;
        if (e.key === 'ArrowDown') { e.preventDefault(); setActive(Math.min(active + 1, items.length - 1)); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); setActive(Math.max(active - 1, 0)); }
        else if (e.key === 'Enter' && active >= 0 && active < items.length) {
          e.preventDefault();
          items[active].click();
        }
        else if (e.key === 'Escape') { box.style.display = 'none'; input.blur(); }
      });
      document.addEventListener('click', function(e) {
        if (!e.target.closest('.search-wrapper')) box.style.display = 'none';
      });
    })();
  </script>

</body>
</html>
