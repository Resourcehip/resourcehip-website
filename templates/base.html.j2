<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }} — Resourcehip</title>
  <meta name="description" content="{{ page_description | default('Resourcehip — Human Impact Profiles for everyday products.') }}" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <!-- Self-hosted Montserrat — no Google Fonts CDN (GDPR: no IP sent to Google) -->
  <!-- Run fonts/download_fonts.py once to fetch the .woff2 files -->
  <link rel="stylesheet" href="/fonts/montserrat.css">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* ── Brand ── */
      --hip-blue:        #0E4C8F;
      --hip-blue-deep:   #0A3A6E;
      --hip-blue-tint:   #E6EEF7;
      /* ── Neutrals (warm) ── */
      --mark-black:      #1A1A1A;
      --ink:             #2E3742;
      --muted:           #5C6773;
      --rule:            #DDD9CD;
      --surface:         #F6F4EE;
      --page-bg:         #FBFAF6;
      --card-bg:         #FFFFFF;
      /* ── Footer / inverse ── */
      --footer-bg:       #0A2440;
      --footer-fg:       #F6F4EE;
      --footer-link:     #A8C4E6;
      /* ── HIP Mark tier colours (brand-locked — do not adjust) ── */
      --tier-emerald:    #3a9e62;
      --tier-slate:      #7a9ab8;
      --tier-amber:      #c8920a;
      /* ── Tier text-safe variants (WCAG AA body text on --page-bg — §3.4 colour spec v1.1) ── */
      --tier-emerald-text: #2a6e44;
      --tier-slate-text:   #4a6a88;
      --tier-amber-text:   #8a5a00;
      /* ── Regenerative Index ramp (methodology data viz — §3.5 colour spec) ── */
      --ri-depleting:    #c04040;
      --ri-extractive:   #c8920a;
      --ri-renewable:    #4FA9A5;
      --ri-restorative:  #7ab85a;
      --ri-regenerative: #3a9e62;
      /* ── Functional ── */
      --positive:        #3a9e62;
      --negative:        #B5482E;
      --warning-bg:      #FFF8E6;
      --warning-fg:      #6B5400;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--page-bg);
      color: var(--ink);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ── Header ─────────────────────────────────────────────────────────── */
    .site-header {
      background: #fff;
      border-bottom: 1px solid var(--rule);
      padding: 0.75rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 1px 8px rgba(0,0,0,0.06);
    }

    .site-header .logo-link img {
      height: 48px;
      width: auto;
      display: block;
    }

    .site-nav {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .site-nav a {
      font-size: 0.82rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      text-decoration: none;
      transition: color 0.2s;
    }

    .site-nav a:hover,
    .site-nav a.active { color: var(--hip-blue); }

    .site-nav a.nav-cta {
      background: linear-gradient(135deg, var(--hip-blue), var(--hip-blue-deep));
      color: #fff;
      padding: 0.45rem 1.1rem;
      border-radius: 6px;
      letter-spacing: 0.06em;
    }

    .site-nav a.nav-cta:hover { opacity: 0.9; color: #fff; }

    /* ── Main content area ──────────────────────────────────────────────── */
    .site-main {
      flex: 1;
      width: 100%;
      max-width: 900px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
    }

    .site-main.wide {
      max-width: 1100px;
    }

    /* ── Shared card ────────────────────────────────────────────────────── */
    .card {
      background: var(--card-bg);
      border: 1px solid var(--rule);
      border-radius: 12px;
      padding: 2rem;
      margin-bottom: 1.5rem;
    }

    /* ── Shared typography ──────────────────────────────────────────────── */
    h1 { font-size: 1.75rem; font-weight: 700; color: var(--mark-black); margin-bottom: 0.5rem; }
    h2 { font-size: 1.2rem; font-weight: 700; color: var(--ink); margin: 2rem 0 0.75rem; }
    h3 { font-size: 1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
    p  { line-height: 1.75; margin-bottom: 1rem; }
    a  { color: var(--hip-blue); }
    ul, ol { padding-left: 1.4rem; line-height: 1.8; }

    hr { border: none; border-top: 1px solid var(--rule); margin: 2rem 0; }

    /* ── Pill / badge ────────────────────────────────────────────────────── */
    .pill {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 0.3rem 0.9rem;
      border-radius: 20px;
      background: var(--surface);
      color: var(--ink);
    }

    /* ── Skip link (WCAG 2.4.1 Bypass Blocks) ─────────────────────────── */
    .skip-link {
      position: absolute;
      top: -100%;
      left: 0;
      background: var(--hip-blue);
      color: #fff;
      padding: 0.6rem 1.2rem;
      z-index: 9999;
      font-weight: 700;
      font-size: 0.9rem;
      text-decoration: none;
      border-radius: 0 0 6px 0;
      transition: top 0.15s;
    }
    .skip-link:focus { top: 0; }

    /* ── Focus styles (WCAG 2.4.7 Focus Visible) ────────────────────── */
    *:focus-visible {
      outline: 3px solid var(--hip-blue);
      outline-offset: 3px;
      border-radius: 3px;
    }

    /* ── Footer ─────────────────────────────────────────────────────────── */
    .site-footer {
      background: var(--footer-bg);
      color: var(--footer-fg);
      text-align: center;
      padding: 1.5rem 2rem;
      font-size: 0.72rem;
      letter-spacing: 0.05em;
    }

    .site-footer a { color: var(--footer-link); text-decoration: none; }

    /* ── Responsive ─────────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .site-header { padding: 0.75rem 1rem; }
      .site-nav { gap: 1rem; }
      .site-nav a.nav-cta { display: none; }
      .site-main { padding: 1.5rem 1rem 3rem; }
    }

    {% block extra_styles %}{% endblock %}
  </style>
  {% block head_meta %}{% endblock %}
</head>
<body>

  <!-- Skip to main content (WCAG 2.4.1) -->
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="site-header">
    <a class="logo-link" href="/">
      <img src="/logo.png" alt="Resourcehip home" />
    </a>
    <nav class="site-nav" aria-label="Main navigation">
      <a href="/" {% if active_page == 'home' %}class="active" aria-current="page"{% endif %}>Home</a>
      <a href="/ratings/" {% if active_page == 'ratings' %}class="active" aria-current="page"{% endif %}>Ratings</a>
      <a href="/blog/" {% if active_page == 'blog' %}class="active" aria-current="page"{% endif %}>Blog</a>
      <a href="/methodology" {% if active_page == 'methodology' %}class="active" aria-current="page"{% endif %}>Methodology</a>
      <a href="/about" {% if active_page == 'about' %}class="active" aria-current="page"{% endif %}>About</a>
      <a href="/faq" {% if active_page == 'faq' %}class="active" aria-current="page"{% endif %}>FAQ</a>
      <a href="/verified-ratings" {% if active_page == 'verified-ratings' %}class="active" aria-current="page"{% endif %}>Verified Ratings</a>
      <a href="/pricing" {% if active_page == 'pricing' %}class="active" aria-current="page"{% endif %}>Pricing</a>
      <a href="/submit" class="nav-cta">Submit a Product</a>
    </nav>
  </header>

  <main id="main-content" class="site-main {% block main_class %}{% endblock %}">
    {% block content %}{% endblock %}
  </main>

  <footer class="site-footer">
    <div>&copy; 2026 Resourcehip Ltd &nbsp;&middot;&nbsp; Reg. SC873386 &nbsp;&middot;&nbsp; Office 90, Alloa Business Centre, Whins Road, Alloa, Clackmannanshire, FK10&nbsp;3SA, Scotland</div>
    <!-- TODO: add VAT no. once registered (only required if VAT-registered) -->
    <div style="margin-top:0.4rem;">
      <span id="rh-email"></span> &nbsp;|&nbsp;
      <a href="/methodology">Methodology v{{ methodology_version | default('1.3') }}</a> &nbsp;|&nbsp;
      <a href="/privacy">Privacy</a> &nbsp;|&nbsp;
      <a href="/terms">Terms</a> &nbsp;|&nbsp;
      <a href="/cookies">Cookies &amp; AI</a>
    </div>
  </footer>
  <script>
    /* Email obfuscation — assembled at runtime to deter address harvesting bots */
    (function() {
      var u = 'hello', d = ['resourcehip', 'com'].join('.');
      var addr = u + '\u0040' + d;
      var el = document.getElementById('rh-email');
      if (el) el.innerHTML = '<a href="mailto:' + addr + '">' + addr + '</a>';
    })();
  </script>

</body>
</html>
