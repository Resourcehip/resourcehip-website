{% extends "base.html.j2" %}

{% block extra_styles %}
.contact-page { max-width: 640px; }
.contact-page h1 { margin-bottom: 0.5rem; }
.contact-intro { margin-bottom: 2rem; }
.contact-intro p { color: var(--muted); line-height: 1.8; }

.contact-form { max-width: 520px; }
.form-group { margin-bottom: 1.25rem; }
.form-group label {
  display: block; font-weight: 600; font-size: 0.85rem;
  margin-bottom: 0.3rem; color: var(--ink);
}
.form-group .required { color: var(--negative); }
.form-group .optional { font-weight: 400; color: var(--muted); }
.form-group input,
.form-group select,
.form-group textarea {
  width: 100%; font-family: 'Montserrat', sans-serif; font-size: 0.88rem;
  padding: 0.6rem 0.8rem; border: 1px solid var(--rule); border-radius: 6px;
  background: var(--card-bg); color: var(--ink); transition: border-color 0.2s;
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--hip-blue); outline: none;
  box-shadow: 0 0 0 3px rgba(14, 76, 143, 0.1);
}
.form-group textarea { min-height: 140px; resize: vertical; }
.form-group select { appearance: auto; }
.form-error {
  color: var(--negative); font-size: 0.78rem; margin-top: 0.25rem; display: none;
}
.form-group.has-error input,
.form-group.has-error select,
.form-group.has-error textarea { border-color: var(--negative); }
.form-group.has-error .form-error { display: block; }

.hp-field { position: absolute; left: -9999px; opacity: 0; height: 0; width: 0; overflow: hidden; }

.contact-submit {
  background: linear-gradient(135deg, var(--hip-blue), var(--hip-blue-deep));
  color: #fff; border: none; padding: 0.7rem 2rem; border-radius: 6px;
  font-family: 'Montserrat', sans-serif; font-weight: 600; font-size: 0.88rem;
  cursor: pointer; transition: opacity 0.2s; min-height: 44px; min-width: 44px;
}
.contact-submit:hover { opacity: 0.9; }
.contact-submit:disabled { opacity: 0.5; cursor: not-allowed; }

.contact-success,
.contact-error-banner { display: none; }
.contact-success.visible,
.contact-error-banner.visible { display: block; }
.contact-success {
  background: var(--hip-blue-tint); border: 1px solid var(--hip-blue);
  border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem;
}
.contact-success h2 { color: var(--hip-blue); margin-top: 0; }
.contact-error-banner {
  background: #fef2f2; border: 1px solid var(--negative);
  border-radius: 8px; padding: 1.5rem; margin-bottom: 1.5rem;
}
.contact-error-banner h2 { color: var(--negative); margin-top: 0; }

.contact-footnote {
  font-size: 0.82rem; color: var(--muted); margin-top: 1.5rem; max-width: 520px;
}

@media (max-width: 640px) {
  .contact-form { max-width: 100%; }
  .contact-submit { width: 100%; }
}
{% endblock %}

{% block content %}
<div class="contact-page">
  <div class="contact-intro">
    <h1>Get in touch</h1>
    <p>Questions about the HIP methodology, verified ratings, or the HIP Mark? Send us a message and we'll reply within two working days.</p>
  </div>

  <div id="contact-success" class="contact-success" role="status">
    <h2>Thanks &mdash; we've got your message.</h2>
    <p>Expect a reply within two working days.</p>
  </div>

  <div id="contact-error-banner" class="contact-error-banner" role="alert">
    <h2>Something went wrong</h2>
    <p id="contact-error-text">Please try again, or email us directly.</p>
  </div>

  <form id="contact-form" class="contact-form" novalidate>
    <div class="form-group">
      <label for="cf-name">Name <span class="required" aria-hidden="true">*</span></label>
      <input type="text" id="cf-name" name="name" required autocomplete="name" maxlength="100">
      <div class="form-error" id="cf-name-error" role="alert" aria-live="polite"></div>
    </div>

    <div class="form-group">
      <label for="cf-email">Email <span class="required" aria-hidden="true">*</span></label>
      <input type="email" id="cf-email" name="email" required autocomplete="email" maxlength="254" aria-describedby="cf-email-error">
      <div class="form-error" id="cf-email-error" role="alert" aria-live="polite"></div>
    </div>

    <div class="form-group">
      <label for="cf-company">Company <span class="optional">(optional)</span></label>
      <input type="text" id="cf-company" name="company" autocomplete="organization" maxlength="100">
    </div>

    <div class="form-group">
      <label for="cf-reason">Reason <span class="optional">(optional)</span></label>
      <select id="cf-reason" name="reason">
        <option value="">&#8212; Select &#8212;</option>
        <option value="verified-rating">Verified rating enquiry</option>
        <option value="press">Press</option>
        <option value="general">General</option>
      </select>
    </div>

    <div class="form-group">
      <label for="cf-message">Message <span class="required" aria-hidden="true">*</span></label>
      <textarea id="cf-message" name="message" required maxlength="5000" aria-describedby="cf-message-error"></textarea>
      <div class="form-error" id="cf-message-error" role="alert" aria-live="polite"></div>
    </div>

    <!-- Honeypot field — bots fill this, humans never see it -->
    <div class="hp-field" aria-hidden="true">
      <label for="cf-website">Website</label>
      <input type="text" id="cf-website" name="website" tabindex="-1" autocomplete="off">
    </div>

    <button type="submit" class="contact-submit" id="contact-submit">Send message</button>
  </form>

  <p class="contact-footnote">All enquiries are read by a human at Resourcehip Ltd, UK.</p>
  <p class="contact-footnote" style="margin-top: 0.4rem;">Prefer email? <span id="contact-email-link"></span></p>
</div>

<script>
(function() {
  var form = document.getElementById('contact-form');
  var btn = document.getElementById('contact-submit');
  var success = document.getElementById('contact-success');
  var errorBanner = document.getElementById('contact-error-banner');
  var errorText = document.getElementById('contact-error-text');

  var u = 'hello', d = ['resourcehip', 'com'].join('.');
  var addr = u + '@' + d;
  var el = document.getElementById('contact-email-link');
  if (el) el.innerHTML = '<a href="mailto:' + addr + '">' + addr + '</a>';

  function validateEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }

  function showError(id, msg) {
    var group = document.getElementById(id).closest('.form-group');
    group.classList.add('has-error');
    var err = document.getElementById(id + '-error');
    if (err) err.textContent = msg;
  }

  function clearErrors() {
    var groups = form.querySelectorAll('.form-group.has-error');
    for (var i = 0; i < groups.length; i++) {
      groups[i].classList.remove('has-error');
      var err = groups[i].querySelector('.form-error');
      if (err) err.textContent = '';
    }
    errorBanner.classList.remove('visible');
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    clearErrors();

    var name = form.elements['name'].value.trim();
    var email = form.elements['email'].value.trim();
    var message = form.elements['message'].value.trim();
    var hp = form.elements['website'].value;

    if (hp) { success.classList.add('visible'); form.style.display = 'none'; return; }

    var valid = true;
    if (!name) { showError('cf-name', 'Please enter your name.'); valid = false; }
    if (!email) { showError('cf-email', 'Please enter your email address.'); valid = false; }
    else if (!validateEmail(email)) { showError('cf-email', 'Please enter a valid email address.'); valid = false; }
    if (!message) { showError('cf-message', 'Please enter a message.'); valid = false; }
    if (!valid) return;

    btn.disabled = true;
    btn.textContent = 'Sending…';

    fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: name,
        email: email,
        company: form.elements['company'].value.trim(),
        reason: form.elements['reason'].value,
        message: message
      })
    })
    .then(function(res) {
      return res.json().then(function(body) { return { ok: res.ok, body: body }; });
    })
    .then(function(r) {
      if (r.ok) {
        form.style.display = 'none';
        success.classList.add('visible');
      } else {
        errorText.textContent = r.body.error || 'Please try again, or email us directly.';
        errorBanner.classList.add('visible');
        btn.disabled = false;
        btn.textContent = 'Send message';
      }
    })
    .catch(function() {
      errorText.textContent = 'Network error — please try again, or email us directly.';
      errorBanner.classList.add('visible');
      btn.disabled = false;
      btn.textContent = 'Send message';
    });
  });
})();
</script>
{% endblock %}
