{% extends "base.html.j2" %}

{% block extra_styles %}
/* ── Rating page specific styles ──────────────────────────────────────── */

/* Score header */
.rating-header { margin-bottom: 1.5rem; }
.rating-meta { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; margin-bottom: 0.75rem; }
.rating-type-badge {
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em;
  text-transform: uppercase; padding: 0.25rem 0.75rem; border-radius: 20px;
}
.badge-generic  { background: var(--surface); color: var(--ink); border: 1px solid var(--rule); }
.badge-verified { background: var(--hip-blue-tint); color: var(--hip-blue); border: 1px solid var(--hip-blue); }

/* HIP Score + RI two-panel card */
.score-panel {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}
@media (max-width: 560px) { .score-panel { grid-template-columns: 1fr; } }

.hip-score-card, .ri-card {
  border: 1px solid var(--rule);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  background: #fff;
}

.hip-score-card { border-top: 4px solid var(--tier-colour, var(--hip-blue)); }

.score-label {
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em;
  text-transform: uppercase; color: #888; margin-bottom: 0.5rem;
}
.score-value {
  font-size: 3.5rem; font-weight: 700;
  color: var(--tier-colour, var(--hip-blue));
  line-height: 1;
}
.score-denom { font-size: 1.2rem; font-weight: 400; color: #666; } /* was #aaa — failed WCAG AA */
.score-tier-name {
  font-size: 0.8rem; font-weight: 600; color: var(--tier-colour);
  margin-top: 0.4rem; letter-spacing: 0.06em;
}
.score-vs-baseline {
  font-size: 0.72rem; color: var(--muted); margin-top: 0.5rem;
}
.score-vs-ceiling {
  font-size: 0.72rem; color: var(--muted); margin-top: 0.2rem;
}
.vs-positive { color: var(--tier-emerald); font-weight: 600; }
.vs-negative { color: var(--tier-amber); font-weight: 600; }

/* RI card */
.ri-score-value {
  font-size: 3rem; font-weight: 700; line-height: 1;
}
.ri-descriptor {
  font-size: 0.85rem; font-weight: 700; margin-top: 0.4rem;
  letter-spacing: 0.06em;
}
.ri-scale {
  display: flex; justify-content: center; gap: 2px;
  margin: 0.75rem auto 0; max-width: 160px;
}
.ri-pip {
  flex: 1; height: 6px; border-radius: 3px; background: var(--rule);
}
.ri-pip.active { background: var(--ri-colour); }

/* Dimension bars */
.dimensions-grid { display: flex; flex-direction: column; gap: 0.85rem; }

.dim-row { display: grid; grid-template-columns: 160px 1fr 48px; gap: 0.75rem; align-items: center; }
@media (max-width: 560px) {
  .dim-row { grid-template-columns: 1fr; gap: 0.25rem; }
  .dim-bar-wrap { order: 2; }
  .dim-score-num { order: 3; text-align: left; }
}

.dim-name {
  font-size: 0.78rem; font-weight: 600; color: var(--ink);
  line-height: 1.3;
}
.dim-weight { font-size: 0.68rem; color: #666; font-weight: 400; } /* was #aaa — critical WCAG AA fail (2.32:1) */

.dim-bar-wrap {
  background: var(--rule); border-radius: 6px; height: 12px; overflow: hidden;
}
.dim-bar {
  height: 100%; border-radius: 6px;
  transition: width 0.6s ease;
}
.bar-high   { background: linear-gradient(to right, var(--tier-emerald), #5db878); }
.bar-medium { background: linear-gradient(to right, #e0a020, var(--tier-amber)); }
.bar-low    { background: linear-gradient(to right, var(--negative), #d56e54); }

.dim-score-num {
  font-size: 0.85rem; font-weight: 700; text-align: right;
  color: var(--ink);
}

.dim-detail {
  grid-column: 1 / -1;
  margin-top: -0.4rem;
}
.dim-finding-toggle {
  font-size: 0.72rem; color: var(--hip-blue); cursor: pointer;
  list-style: none; font-weight: 600;
}
.dim-finding-toggle::-webkit-details-marker { display: none; }
.dim-finding {
  font-size: 0.75rem; color: #666; line-height: 1.5;
  margin-top: 0.4rem;
  border-left: 2px solid var(--rule);
  padding-left: 0.6rem;
}

/* Rendered markdown body */
.rating-body h2 { font-size: 1.1rem; margin: 2rem 0 0.5rem; color: var(--hip-blue); }
.rating-body h3 { font-size: 0.95rem; }
.rating-body table {
  width: 100%; border-collapse: collapse; font-size: 0.82rem;
  margin: 1rem 0;
}
.rating-body th {
  background: var(--surface); font-weight: 600; text-align: left;
  padding: 0.5rem 0.75rem; border: 1px solid var(--rule);
}
.rating-body td { padding: 0.45rem 0.75rem; border: 1px solid var(--rule); }
.rating-body blockquote {
  border-left: 3px solid var(--hip-blue); padding: 0.5rem 1rem;
  background: var(--hip-blue-tint); border-radius: 0 6px 6px 0;
  color: var(--ink); font-size: 0.85rem; margin: 1rem 0;
}
.rating-body ul { margin-bottom: 1rem; }

/* HIP Mark badge */
.hip-mark-banner {
  display: flex; align-items: center; gap: 1.25rem;
  padding: 0.85rem 1.25rem;
  border-radius: 8px; margin-bottom: 1.25rem;
  border: 1.5px solid;
}
.hip-mark-banner.mark-gold     { background: #fffbea; border-color: var(--tier-amber); }
.hip-mark-banner.mark-silver   { background: #f2f6fb; border-color: var(--tier-slate); }
.hip-mark-banner.mark-standard { background: #f0f8f4; border-color: var(--tier-emerald); }
.hip-mark-badge-img {
  flex-shrink: 0; width: 52px; height: auto;
}
.hip-mark-text { line-height: 1.4; }
.hip-mark-title {
  font-size: 0.88rem; font-weight: 700;
  display: block; margin-bottom: 0.15rem;
}
.hip-mark-title.mark-gold     { color: var(--tier-amber-text); }
.hip-mark-title.mark-silver   { color: var(--tier-slate-text); }
.hip-mark-title.mark-standard { color: var(--tier-emerald-text); }
.hip-mark-desc { font-size: 0.75rem; color: #666; }

/* §4 Summary sentence */
.summary-sentence {
  font-size: 0.95rem;
  line-height: 1.65;
  color: var(--ink);
  margin: 0 0 1.5rem;
}

/* Generic rating notice */
.generic-notice {
  background: var(--warning-bg); border: 1px solid var(--rule);
  border-left: 4px solid var(--tier-amber);
  border-radius: 0 8px 8px 0; padding: 0.9rem 1.25rem;
  font-size: 0.8rem; line-height: 1.65; color: var(--warning-fg);
  margin-bottom: 1.25rem;
}
.generic-notice strong { display: block; margin-bottom: 0.25rem; }

/* Data sources */
.data-sources {
  font-size: 0.75rem; color: #666; line-height: 1.6; /* was #888 — failed WCAG AA at this size */
  margin-top: 0.5rem;
}
.data-sources strong { color: var(--ink); }

/* Disclaimer */
.disclaimer-box {
  background: var(--surface); border: 1px solid var(--rule);
  border-radius: 8px; padding: 1.25rem 1.5rem;
  font-size: 0.78rem; line-height: 1.7; color: #666;
  margin-top: 2rem;
}
.disclaimer-box p { margin-bottom: 0.5rem; }

/* Score hierarchy (category pages) */
.score-ceiling-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #888; margin-bottom: 0.4rem; }
.score-ceiling-value { font-size: 3.5rem; font-weight: 700; color: var(--tier-colour, var(--hip-blue)); line-height: 1; }
.score-baseline-row { font-size: 0.88rem; font-weight: 600; color: #555; margin-top: 0.7rem; }
.score-baseline-label { font-size: 0.7rem; color: var(--muted); font-weight: 400; display: block; margin-top: 0.15rem; }

/* §1 Category page boilerplate */
.score-boilerplate { background: var(--surface); border: 1px solid var(--rule); border-radius: 8px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; font-size: 0.85rem; line-height: 1.75; color: var(--ink); }
.score-boilerplate strong { display: block; font-size: 0.88rem; color: var(--hip-blue); margin-bottom: 0.5rem; }

/* §3a+§3b Manufacturer CTA */
.mfr-cta-block { background: var(--hip-blue-tint); border: 1px solid var(--rule); border-left: 4px solid var(--hip-blue); border-radius: 0 8px 8px 0; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; }
.mfr-cta-block h3 { font-size: 0.92rem; font-weight: 700; margin: 0 0 0.75rem; color: var(--hip-blue); }
.mfr-cta-block p { font-size: 0.82rem; line-height: 1.75; color: var(--ink); margin-bottom: 0.75rem; }
.btn-verified-assessment { display: inline-block; background: var(--hip-blue); color: #fff; font-weight: 700; font-size: 0.85rem; padding: 0.65rem 1.5rem; border-radius: 6px; text-decoration: none; letter-spacing: 0.02em; transition: background 0.2s; }
.btn-verified-assessment:hover { background: var(--hip-blue-deep); }

/* §2c Methodology disclosure */
.methodology-disclosure { margin-top: 1.25rem; border-top: 1px solid var(--rule); padding-top: 1rem; }
.methodology-disclosure summary { font-size: 0.75rem; color: var(--hip-blue); cursor: pointer; list-style: none; font-weight: 600; }
.methodology-disclosure summary::-webkit-details-marker { display: none; }
.methodology-disclosure-body { font-size: 0.78rem; color: var(--ink); line-height: 1.7; margin-top: 0.75rem; background: var(--hip-blue-tint); border-left: 2px solid var(--hip-blue); padding: 0.75rem 1rem; border-radius: 0 6px 6px 0; }

/* ── Consumer Score Unit (HIP Mark badge + position bar + RI chip) ────── */
.consumer-score-unit {
  background: var(--card-bg);
  border: 1px solid var(--rule);
  border-radius: 12px;
  padding: 1.5rem 1.5rem 1.25rem;
  margin-bottom: 1.5rem;
}
.csu-badge-row {
  display: flex; align-items: center; gap: 1rem; margin-bottom: 1.25rem;
}
.csu-shield { flex-shrink: 0; width: 56px; height: auto; }
.csu-tier-name {
  display: block; font-size: 1.15rem; font-weight: 700; letter-spacing: 0.01em;
}
.csu-no-mark { color: var(--muted); }
.csu-score-line {
  display: block; font-size: 0.82rem; color: var(--muted); margin-top: 0.15rem;
}

.csu-bar-wrap { margin-bottom: 1rem; position: relative; padding: 0 9px; }
.csu-bar-track {
  display: flex; height: 12px; position: relative;
}
.csu-zone { height: 100%; }
.csu-zone-below    { background: var(--rule); width: 60%; border-radius: 6px 0 0 6px; }
.csu-zone-standard { background: var(--tier-emerald); opacity: 0.22; width: 15%; }
.csu-zone-silver   { background: var(--tier-slate);   opacity: 0.22; width: 15%; }
.csu-zone-gold     { background: var(--tier-amber);   opacity: 0.22; width: 10%; border-radius: 0 6px 6px 0; }
.csu-marker {
  position: absolute; top: 50%;
  width: 18px; height: 18px; border-radius: 50%;
  background: var(--tier-colour, var(--hip-blue));
  border: 3px solid var(--card-bg);
  box-shadow: 0 1px 4px rgba(0,0,0,0.18);
  transform: translate(-50%, -50%); z-index: 2;
}
.csu-marker-label {
  position: absolute; top: -20px;
  font-size: 0.68rem; font-weight: 700; color: var(--tier-colour, var(--ink));
  transform: translateX(-50%); white-space: nowrap;
}
.csu-threshold {
  position: absolute; top: 0; width: 1px; height: 100%;
  background: var(--card-bg); opacity: 0.7; z-index: 1;
}
.csu-zone-labels {
  position: relative; height: 1.4rem; margin-top: 0.3rem;
}
.csu-label {
  position: absolute;
  font-size: 0.62rem; font-weight: 600; text-transform: uppercase;
  letter-spacing: 0.08em; color: var(--muted); transform: translateX(-50%);
}
@media (max-width: 400px) {
  .csu-label { font-size: 0.55rem; letter-spacing: 0.04em; }
}

.csu-ri-row {
  display: flex; align-items: center; gap: 0.6rem;
  padding-top: 0.85rem; border-top: 1px solid var(--rule);
}
.csu-ri-chip { flex-shrink: 0; width: 26px; height: 26px; }
.csu-ri-text { font-size: 0.8rem; color: var(--ink); line-height: 1.4; }

/* §5 Ceiling page hero */
.ceiling-hero { background: var(--hip-blue-tint); border: 1px solid var(--rule); border-radius: 12px; padding: 1.75rem 2rem; margin-bottom: 1.75rem; }
.ceiling-hero-eyebrow { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--hip-blue); margin-bottom: 0.5rem; }
.ceiling-hero-score { font-size: 2.8rem; font-weight: 700; color: var(--tier-colour, var(--hip-blue)); line-height: 1.1; margin-bottom: 0.75rem; }
.ceiling-hero-copy { font-size: 0.85rem; line-height: 1.75; color: var(--ink); }
{% endblock %}

{% block main_class %}{% endblock %}

{% block content %}

{# ── Tier colour logic (methodology.yaml thresholds: 6.0/7.5/9.0+RI≥6) ── #}
{%- set _hip_mark_val = hip_mark | default(none) -%}
{%- if _hip_mark_val -%}
  {%- set mark_tier = _hip_mark_val | lower -%}
{%- elif hip_score >= 9.0 and ri_score >= 6.0 -%}
  {%- set mark_tier = 'gold' -%}
{%- elif hip_score >= 7.5 -%}
  {%- set mark_tier = 'silver' -%}
{%- elif hip_score >= 6.0 -%}
  {%- set mark_tier = 'standard' -%}
{%- else -%}
  {%- set mark_tier = 'none' -%}
{%- endif -%}

{%- if mark_tier == 'gold' -%}
  {%- set tier_colour      = 'var(--tier-amber)' -%}
  {%- set score_band_name  = 'Gold' -%}
  {%- set score_band_label = 'Gold' -%}
{%- elif mark_tier == 'silver' -%}
  {%- set tier_colour      = 'var(--tier-slate)' -%}
  {%- set score_band_name  = 'Silver' -%}
  {%- set score_band_label = 'Silver' -%}
{%- elif mark_tier == 'standard' -%}
  {%- set tier_colour      = 'var(--tier-emerald)' -%}
  {%- set score_band_name  = 'Standard' -%}
  {%- set score_band_label = 'Standard' -%}
{%- else -%}
  {%- set tier_colour      = 'var(--mark-black)' -%}
  {%- set score_band_name  = 'Below Standard' -%}
  {%- set score_band_label = 'Below Standard' -%}
{%- endif -%}

{# ── RI colour logic ────────────────────────────────────────────────────── #}
{%- if ri_descriptor == 'Regenerative' -%}
  {%- set ri_colour = 'var(--ri-regenerative)' -%}
{%- elif ri_descriptor == 'Restorative' -%}
  {%- set ri_colour = 'var(--ri-restorative)' -%}
{%- elif ri_descriptor == 'Renewable' -%}
  {%- set ri_colour = 'var(--ri-renewable)' -%}
{%- elif ri_descriptor == 'Extractive' -%}
  {%- set ri_colour = 'var(--ri-extractive)' -%}
{%- else -%}
  {%- set ri_colour = 'var(--ri-depleting)' -%}
{%- endif -%}

<style>
  :root {
    --tier-colour: {{ tier_colour }};
    --ri-colour:   {{ ri_colour }};
  }
</style>

{# ── §5 Ceiling page hero ─────────────────────────────────────────────────── #}
{% if brand == 'Category Ceiling' %}
<div class="ceiling-hero">
  <div class="ceiling-hero-eyebrow">Category ceiling</div>
  <div class="ceiling-hero-score">{{ "%.1f"|format(hip_score) }} <span style="font-size:1.2rem;font-weight:400;color:#666;">HIP</span></div>
  <div class="ceiling-hero-copy">
    This is the best score a product in this category can reach when the maker shares full data about
    its materials, supply chain, repairs, and end-of-life. It is a target, not a product on sale today.
  </div>
</div>
{% endif %}

<!-- ── Generic rating notice ──────────────────────────────────────────────── -->
{% if rating_type != 'verified' %}
<div class="generic-notice">
  <strong>Category rating — not an assessment of any specific brand</strong>
  This rating covers a typical, mass-market <em>{{ category }}</em> product based on publicly available data.
  It does not name or assess any specific manufacturer or product.
  Individual products may perform better or worse.
  <a href="/about#two-types-of-rating">Learn about verified ratings →</a>
</div>
{% endif %}

<!-- ── Rating header ─────────────────────────────────────────────────────── -->
<div class="rating-header">
  <div class="rating-meta">
    {% if rating_type == 'verified' %}
      <span class="rating-type-badge badge-verified">✓ Verified Rating</span>
    {% else %}
      <span class="rating-type-badge badge-generic">Category Rating</span>
    {% endif %}
    <span class="pill">{{ category }}</span>
    <span class="pill">Assessed {{ assessment_date }}</span>
    <span class="pill">{{ methodology_version }}</span>
  </div>
  <h1>{{ title }}</h1>
  {% if rating_type == 'verified' and brand %}
    <p style="font-size:1rem; color:#666; margin-top:0.25rem;">{{ brand }}</p>
  {% endif %}
</div>

<!-- ── Consumer Score Visualisation ────────────────────────────────────── -->
{% if brand != 'Category Ceiling' %}
<div class="consumer-score-unit" role="region" aria-label="HIP Score summary">

  <div class="csu-badge-row">
    {% if mark_tier != 'none' %}
    <img class="csu-shield"
         src="/assets/marks/hip-mark-shield-{{ mark_tier }}.svg"
         alt="HIP Mark {{ score_band_name }}" width="56" height="66" loading="lazy">
    {% endif %}
    <div class="csu-text">
      {% if mark_tier != 'none' %}
        <span class="csu-tier-name" style="color: var(--tier-colour);">{{ score_band_name }} HIP Mark</span>
        <span class="csu-score-line">Score {{ "%.1f"|format(hip_score) }}/10</span>
      {% else %}
        <span class="csu-tier-name csu-no-mark">Below HIP Mark threshold</span>
        <span class="csu-score-line">Score {{ "%.1f"|format(hip_score) }}/10 — Standard mark requires 6.0</span>
      {% endif %}
    </div>
  </div>

  <div class="csu-bar-wrap"
       role="img"
       aria-label="Score {{ "%.1f"|format(hip_score) }} out of 10. Standard threshold at 6.0, Silver at 7.5, Gold at 9.0.">
    <div class="csu-bar-track">
      <div class="csu-zone csu-zone-below"></div>
      <div class="csu-zone csu-zone-standard"></div>
      <div class="csu-zone csu-zone-silver"></div>
      <div class="csu-zone csu-zone-gold"></div>
      <div class="csu-threshold" style="left: 60%;"></div>
      <div class="csu-threshold" style="left: 75%;"></div>
      <div class="csu-threshold" style="left: 90%;"></div>
      <div class="csu-marker" style="left: {{ (hip_score / 10 * 100) | round(1) }}%;">
        <span class="csu-marker-label">{{ "%.1f"|format(hip_score) }}</span>
      </div>
    </div>
    <div class="csu-zone-labels">
      <span class="csu-label" style="left: 60%;">Standard</span>
      <span class="csu-label" style="left: 75%;">Silver</span>
      <span class="csu-label" style="left: 90%;">Gold</span>
    </div>
  </div>

  <div class="csu-ri-row">
    <img class="csu-ri-chip"
         src="/assets/marks/ri-chip-{{ ri_descriptor | lower }}.svg"
         alt="{{ ri_descriptor }}" width="26" height="26" loading="lazy">
    <span class="csu-ri-text">
      <strong style="color: var(--ri-colour);">{{ ri_descriptor }}</strong>
      {%- if ri_descriptor == 'Depleting' %} — materials are being used up with no way to replace them
      {%- elif ri_descriptor == 'Extractive' %} — materials take more from the planet than they give back
      {%- elif ri_descriptor == 'Renewable' %} — materials come from sources that can be renewed
      {%- elif ri_descriptor == 'Restorative' %} — materials or making processes help restore nature
      {%- elif ri_descriptor == 'Regenerative' %} — materials and processes actively regenerate natural systems
      {%- endif %}
    </span>
  </div>

</div>

{# ── §4 Summary sentence ──────────────────────────────────────────────────── #}
{%- set _cat_singular = title|default('product')|singularize -%}

{#- Tier phrase -#}
{%- set _hip_mark_val = hip_mark|default(none) -%}
{%- if _hip_mark_val == 'Gold' -%}
  {%- set _tier_phrase = 'This ' ~ _cat_singular ~ ' earns the Gold HIP Mark.' -%}
{%- elif _hip_mark_val == 'Silver' -%}
  {%- set _tier_phrase = 'This ' ~ _cat_singular ~ ' earns the Silver HIP Mark.' -%}
{%- elif _hip_mark_val == 'Standard' -%}
  {%- set _tier_phrase = 'This ' ~ _cat_singular ~ ' earns the Standard HIP Mark.' -%}
{%- else -%}
  {%- set _tier_phrase = 'This is what a typical ' ~ _cat_singular ~ ' looks like today.' -%}
{%- endif -%}

{#- Benefit phrase — pick dimension with highest score (RI normalised to 0-10) -#}
{%- set _scores = [
  ('msi', msi_score|default(0)|float),
  ('scr', scr_score|default(0)|float),
  ('rc',  rc_score|default(0)|float),
  ('r',   r_score|default(0)|float),
  ('sei', sei_score|default(0)|float),
  ('pl',  pl_score|default(0)|float),
  ('ri',  ((ri_score|default(0)|float + 10) / 2)),
] -%}
{%- set _top = namespace(dim='msi', val=-999) -%}
{%- for dim, score in _scores -%}
  {%- if score > _top.val -%}
    {%- set _top.dim = dim -%}
    {%- set _top.val = score -%}
  {%- endif -%}
{%- endfor -%}

{%- if _top.dim == 'msi' -%}
  {%- set _benefit = 'It uses materials that hold up better than average.' -%}
{%- elif _top.dim == 'scr' -%}
  {%- set _benefit = 'The makers know where their materials come from.' -%}
{%- elif _top.dim == 'rc' -%}
  {%- set _benefit = "It's easier to recycle than the typical one." -%}
{%- elif _top.dim == 'r' -%}
  {%- set _benefit = 'You can fix it when something goes wrong.' -%}
{%- elif _top.dim == 'sei' -%}
  {%- set _benefit = "It's made with care for the people and places involved." -%}
{%- elif _top.dim == 'pl' -%}
  {%- set _benefit = "It's built to last longer than the typical one." -%}
{%- else -%}
  {%- set _benefit = 'It puts less strain on natural materials than average.' -%}
{%- endif -%}

{#- Action phrase -#}
{%- if rating_type == 'verified' -%}
  {%- set _action = 'It carries our mark because the maker has shared the data to prove it.' -%}
{%- else -%}
  {%- set _action = 'If the maker shares their data, the score usually goes up.' -%}
{%- endif -%}

<p class="summary-sentence">{{ _tier_phrase }} {{ _benefit }} {{ _action }}</p>
{% endif %}

<!-- ── HIP Score + RI ─────────────────────────────────────────────────────── -->
<div class="score-panel">

  <div class="hip-score-card">
    {%- set _ceil_hip = category_ceiling_hip|default(none) -%}
    {% if rating_type != 'verified' and _ceil_hip is not none %}
      {# Category page: baseline is primary, ceiling is secondary #}
      <div class="score-label">Category baseline</div>
      <div class="score-value">{{ "%.1f"|format(hip_score) }}<span class="score-denom"> HIP</span></div>
      <div class="score-tier-name">{{ score_band_label }}</div>
      <div class="score-vs-ceiling">
        Category ceiling: {{ "%.1f"|format(_ceil_hip) }} HIP
      </div>
    {% else %}
      {# Verified product (or no ceiling data) — standard display #}
      <div class="score-label">HIP Score</div>
      <div class="score-value">
        {{ "%.1f"|format(hip_score) }}<span class="score-denom">/10</span>
      </div>
      <div class="score-tier-name">{{ score_band_label }}</div>
      <div class="score-vs-baseline">
        {%- set diff = hip_score - category_baseline_hip -%}
        {%- if diff > 0 -%}
          <span class="vs-positive">+{{ "%.1f"|format(diff) }}</span> vs category baseline ({{ "%.1f"|format(category_baseline_hip) }})
        {%- elif diff < 0 -%}
          <span class="vs-negative">{{ "%.1f"|format(diff) }}</span> vs category baseline ({{ "%.1f"|format(category_baseline_hip) }})
        {%- else -%}
          At category baseline ({{ "%.1f"|format(category_baseline_hip) }})
        {%- endif -%}
      </div>
      {% if _ceil_hip is not none %}
      <div class="score-vs-ceiling">
        Category ceiling: {{ "%.1f"|format(_ceil_hip) }} HIP
      </div>
      {% endif %}
    {% endif %}
  </div>

  <div class="ri-card">
    {%- set _ceil_ri = category_ceiling_ri|default(none) -%}
    {%- set ri_tiers = ['Depleting','Extractive','Renewable','Restorative','Regenerative'] -%}
    {%- set ri_pip_colours = ['var(--ri-depleting)','var(--ri-extractive)','var(--ri-renewable)','var(--ri-restorative)','var(--ri-regenerative)'] -%}
    {%- set ri_active_idx = ri_tiers.index(ri_descriptor) if ri_descriptor in ri_tiers else 2 -%}
    {% if rating_type != 'verified' and _ceil_ri is not none %}
      {# Category page: baseline RI is primary, ceiling is secondary #}
      <div class="score-label">Regenerative Index</div>
      <div class="ri-score-value" style="color: {{ ri_pip_colours[ri_active_idx] }};">
        {% if ri_score > 0 %}+{% endif %}{{ "%.1f"|format(ri_score) }}
      </div>
      <div class="ri-descriptor" style="color: {{ ri_pip_colours[ri_active_idx] }};">{{ ri_descriptor }}</div>
      <div class="ri-scale">
        {% for i in range(5) %}
          <div class="ri-pip {% if i <= ri_active_idx %}active{% endif %}"
               style="{% if i <= ri_active_idx %}background:{{ ri_pip_colours[ri_active_idx] }}{% endif %}">
          </div>
        {% endfor %}
      </div>
      <div class="score-vs-ceiling" style="margin-top:0.75rem;">
        Category ceiling RI: {% if _ceil_ri > 0 %}+{% endif %}{{ "%.1f"|format(_ceil_ri) }}
      </div>
    {% else %}
      {# Verified product (or no ceiling data) — standard display #}
      <div class="score-label">Regenerative Index</div>
      <div class="ri-score-value" style="color: var(--ri-colour);">
        {% if ri_score > 0 %}+{% endif %}{{ "%.1f"|format(ri_score) }}
      </div>
      <div class="ri-descriptor" style="color: var(--ri-colour);">{{ ri_descriptor }}</div>
      <!-- RI scale: 5 pips, one per tier (Depleting → Regenerative) -->
      <div class="ri-scale">
        {% for i in range(5) %}
          <div class="ri-pip {% if i <= ri_active_idx %}active{% endif %}"
               style="{% if i <= ri_active_idx %}background:{{ ri_pip_colours[ri_active_idx] }}{% endif %}">
          </div>
        {% endfor %}
      </div>
      <div class="score-vs-baseline" style="margin-top:0.75rem;">
        {%- set ri_diff = ri_score - category_baseline_ri -%}
        {%- if ri_diff > 0 -%}
          <span class="vs-positive">+{{ "%.1f"|format(ri_diff) }}</span> vs category ({{ "%.1f"|format(category_baseline_ri) }})
        {%- elif ri_diff < 0 -%}
          <span class="vs-negative">{{ "%.1f"|format(ri_diff) }}</span> vs category ({{ "%.1f"|format(category_baseline_ri) }})
        {%- else -%}
          At category average ({{ "%.1f"|format(category_baseline_ri) }})
        {%- endif -%}
      </div>
      {% if _ceil_ri is not none %}
      <div class="score-vs-ceiling">
        Category ceiling RI: {% if _ceil_ri > 0 %}+{% endif %}{{ "%.1f"|format(_ceil_ri) }}
      </div>
      {% endif %}
    {% endif %}
  </div>

</div>

{# ── §1 Category page boilerplate ─────────────────────────────────────────── #}
{% if rating_type != 'verified' %}
<div class="score-boilerplate">
  <strong>What this score means</strong>
  This is the starting score for {{ title }}, based only on public data. No maker has sent us
  their own data yet. The ceiling score (shown below) is what a product can reach when the maker
  shares real evidence. To close the gap, makers apply for a verified rating.
</div>
{% endif %}

{# ── §3a+§3b Manufacturer CTA ─────────────────────────────────────────────── #}
{% if rating_type != 'verified' %}
  {%- set _ceil_hip_cta = category_ceiling_hip|default(none) -%}
  {% if _ceil_hip_cta is not none %}
<div class="mfr-cta-block">
  <h3>Make this product? You can raise this score.</h3>
  <p>The starting score for this category is {{ "%.1f"|format(hip_score) }} HIP.
  With full evidence, a product in this category can reach {{ "%.1f"|format(_ceil_hip_cta) }} HIP.
  Our first verified product scored 6.9 and earned the HIP Mark.</p>
  <p>Share your product data and we score what you can prove.</p>
  <a class="btn-verified-assessment" href="/apply">Apply for verified assessment</a>
</div>
  {% endif %}
{% endif %}


<!-- ── Dimension Breakdown ────────────────────────────────────────────────── -->
<div class="card">
  <h2 style="margin-top:0;">Score Breakdown</h2>

  {%- set dimensions = [
    ('How rare are the materials?',        'MSI', msi_score, 20, msi_finding | default('')),
    ('Where do the materials come from?',  'SCR', scr_score, 18, scr_finding | default('')),
    ('Can it be recycled?',                'RC',  rc_score,  18, rc_finding  | default('')),
    ('Can you fix it?',                    'R',   r_score,   13, r_finding   | default('')),
    ('Is it made fairly?',                 'SEI', sei_score,  8, sei_finding | default('')),
    ('How long will it last?',             'PL',  pl_score,   8, pl_finding  | default('')),
  ] -%}

  <div class="dimensions-grid">
    {% for label, code, score, weight, finding in dimensions %}
      {%- if score >= 7.0 -%}{%- set bar_class = 'bar-high' -%}
      {%- elif score >= 4.0 -%}{%- set bar_class = 'bar-medium' -%}
      {%- else -%}{%- set bar_class = 'bar-low' -%}
      {%- endif -%}
      <div class="dim-row">
        <div class="dim-name">
          {{ label }}<br>
          <span class="dim-weight">{{ code }} · {{ weight }}%</span>
        </div>
        <div class="dim-bar-wrap">
          <div class="dim-bar {{ bar_class }}" style="width:{{ (score * 10) | int }}%"></div>
        </div>
        <div class="dim-score-num">{{ "%.1f"|format(score) }}</div>
        {% if finding %}
          <details class="dim-detail">
            <summary class="dim-finding-toggle">Why this score ▸</summary>
            <div class="dim-finding">{{ finding }}</div>
          </details>
        {% endif %}
      </div>
    {% endfor %}

    <!-- RI row (separate — different scale) -->
    {%- if ri_score >= 1 -%}{%- set ri_bar_class = 'bar-high' -%}
    {%- elif ri_score >= -4 -%}{%- set ri_bar_class = 'bar-medium' -%}
    {%- else -%}{%- set ri_bar_class = 'bar-low' -%}
    {%- endif -%}
    {# Normalise −10→+10 to 0–100% for bar #}
    {%- set ri_pct = ((ri_score + 10) / 20 * 100) | int -%}
    <div class="dim-row">
      <div class="dim-name">
        Does it give back to nature?<br>
        <span class="dim-weight">RI · 15% · scale −10 to +10</span>
      </div>
      <div class="dim-bar-wrap">
        <div class="dim-bar {{ ri_bar_class }}" style="width:{{ ri_pct }}%"></div>
      </div>
      <div class="dim-score-num" style="font-size:0.78rem;">
        {% if ri_score > 0 %}+{% endif %}{{ "%.1f"|format(ri_score) }}
      </div>
      {% if ri_finding | default('') %}
        <details class="dim-detail">
          <summary class="dim-finding-toggle">Why this score ▸</summary>
          <div class="dim-finding">{{ ri_finding }}</div>
        </details>
      {% endif %}
    </div>

  </div><!-- /.dimensions-grid -->

  <p style="font-size:0.72rem; color:var(--muted); margin-top:1.25rem; margin-bottom:0;">
    MSI 20% · SCR 18% · RC 18% · R 13% · SEI 8% · PL 8% · RI 15% = 100%
  </p>

  <!-- ── §2c Methodology disclosure ────────────────────────────────────────── -->
  <details class="methodology-disclosure">
    <summary>About the HIP Methodology ▸</summary>
    <div class="methodology-disclosure-body">
      Starting scores are low on purpose. We only count what we can confirm from public data,
      so most products sit between 2 and 4 out of 10 before a maker shares their own evidence.
      That gap between the starting score and what a product could reach is the whole point.
      When a maker proves what their product is really made of, the score goes up.
      The HIP Mark shows it has been checked.
      <a href="/methodology" style="white-space:nowrap;">Read the full methodology →</a>
    </div>
  </details>
</div><!-- /.card -->

<!-- ── Key Materials ───────────────────────────────────────────────────────── -->
{% if key_materials %}
<div class="card">
  <h2 style="margin-top:0;">Key Materials</h2>
  <ul>
    {% for mat in key_materials %}
      <li><strong>{{ mat.name }}</strong> — {{ mat.note }}</li>
    {% endfor %}
  </ul>
</div>
{% endif %}

<!-- ── Consumer sections (from frontmatter or body) ──────────────────────── -->
{% if consumer_summary %}
<div class="card">
  <h2 style="margin-top:0;">Consumer Summary</h2>
  <p>{{ consumer_summary }}</p>
</div>
{% endif %}

{% if what_this_means %}
<div class="card">
  <h2 style="margin-top:0;">What This Means For You</h2>
  <p>{{ what_this_means }}</p>
</div>
{% endif %}

<!-- ── Rendered markdown body (data sources, improvement opps, etc.) ──────── -->
{% if body %}
<div class="card rating-body">
  {{ body }}
</div>
{% endif %}

<!-- ── Data sources ───────────────────────────────────────────────────────── -->
{% if data_sources %}
<div class="card">
  <h2 style="margin-top:0; font-size:0.95rem;">Data Sources</h2>
  <div class="data-sources">
    <strong>This rating draws on the following public sources:</strong><br>
    {% for src in data_sources %}{{ src }}{% if not loop.last %} · {% endif %}{% endfor %}<br>
    All sources are public domain or published under open data licences.
    <a href="/methodology#data-sources">Full source list →</a>
  </div>
</div>
{% endif %}

<!-- ── Disclaimer ─────────────────────────────────────────────────────────── -->
<div class="disclaimer-box">
  <p><strong>About this rating:</strong>
  HIP scores are based on public data{% if rating_type == 'verified' %} and information the maker sent us{% endif %} at the date shown.
  They show how well a product holds up over time — not a promise about safety or future supply.
  Resourcehip is not liable for choices made based on these ratings.</p>
  <p><strong>Scope:</strong>
  {% if rating_type != 'verified' %}
    This is a <em>category rating</em> for {{ title }} and does not assess any specific brand or manufacturer.
    Individual products may perform better or worse than this baseline.
  {% else %}
    This is a <em>verified product rating</em> for {{ brand }}, assessed using manufacturer-submitted data and public category data.
  {% endif %}
  Produced under <a href="/methodology">Resourcehip Scoring Methodology {{ methodology_version }}</a>.</p>
  <p><strong>AI disclosure:</strong>
  An AI model scored this rating on our own hardware — no data was sent to the cloud.
  A human reviewer checked and approved it before it went live.
  {% if scoring_model %}
  Model: <code>{{ scoring_model }}</code>{% if prose_model and prose_model != scoring_model %} · Prose: <code>{{ prose_model }}</code>{% endif %}.
  {% endif %}
  <a href="/cookies">AI transparency notice →</a></p>
  <p><strong>Not financial or investment advice.</strong>
  Ratings are for consumer information only.
  <a href="/dispute">Dispute this rating</a> · <a href="/methodology">Our methodology</a> · <a href="/ratings/">All ratings</a>
  {% if rating_type == 'verified' %} · <a href="/submit">Submit updated data</a>{% endif %}</p>
  <p style="margin-bottom:0; color:var(--muted);">
    Assessed: {{ assessment_date }} · Next review: {{ next_review | default('Annual') }} · Methodology {{ methodology_version }}
  </p>
</div>

{% endblock %}
