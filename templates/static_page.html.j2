{% extends "base.html.j2" %}

{% block extra_styles %}
.static-body { max-width: 680px; }
.static-body h1 { margin-bottom: 1rem; }
.static-body h2 { font-size: 1.1rem; margin: 2rem 0 0.6rem; border-bottom: 1px solid var(--rule); padding-bottom: 0.4rem; }
.static-body h3 { font-size: 0.95rem; margin: 1.5rem 0 0.4rem; }
.static-body p  { line-height: 1.8; margin-bottom: 1rem; }
.static-body ul, .static-body ol { padding-left: 1.4rem; margin-bottom: 1rem; line-height: 1.8; }
.static-body table { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.85rem; }
.static-body th { background: var(--surface); padding: 0.5rem 0.75rem; text-align: left; border: 1px solid var(--rule); font-weight: 600; }
.static-body td { padding: 0.45rem 0.75rem; border: 1px solid var(--rule); vertical-align: top; }
.static-body blockquote { border-left: 3px solid var(--hip-blue); padding: 0.5rem 1rem; background: var(--hip-blue-tint); border-radius: 0 6px 6px 0; margin: 1rem 0; color: var(--muted); font-style: italic; }
.static-body code { font-family: monospace; background: #eee; padding: 0.1em 0.4em; border-radius: 3px; font-size: 0.9em; }
.static-body pre { background: #1e1e1e; color: #d4d4d4; padding: 1rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; }
.static-body pre code { background: none; padding: 0; }
{% endblock %}

{% block content %}
<div class="static-body">
  {{ body }}
</div>
{% endblock %}
